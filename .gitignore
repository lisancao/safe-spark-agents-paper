# real (unredacted) config — only the .example is committed
config/aws.env

# generated reader output (regenerate with paper/tools/render_reader.py)
paper/build/
build/

# raw run archive (shipped as a GitHub Release asset, not committed)
*.tar.gz
dist/

# agent working dirs / generated data (reproducible from seeds; raw archive is the release asset)
**/.work.*
**/_data/

# Terraform — never commit state (holds the RDS master password) or filled tfvars.
# The *.tfvars.example templates ARE committed.
**/.terraform/
*.tfstate
*.tfstate.*
**/terraform.tfvars
**/*.auto.tfvars
crash.log

# spike run artifacts (reproducible via ./run.sh)
deploy/eks/lakekeeper/spike/out/*
!deploy/eks/lakekeeper/spike/out/.gitkeep

# python bytecode
__pycache__/
*.pyc
