# AWS / infra configuration — copy to config/aws.env and fill in your own values.
# config/aws.env is gitignored; the platform code (deploy/, connect/) and runbooks
# reference these as ${VARS} so no account-specific value is committed.

# AWS account + region
AWS_ACCOUNT_ID=000000000000
AWS_REGION=us-east-1

# Container registry (ECR) — usually <account>.dkr.ecr.<region>.amazonaws.com
ECR_REGISTRY=000000000000.dkr.ecr.us-east-1.amazonaws.com

# S3 buckets
WAREHOUSE_BUCKET=my-spark-warehouse          # Iceberg warehouse (s3a://$WAREHOUSE_BUCKET/warehouse)
TFSTATE_BUCKET=my-terraform-state            # Terraform remote state

# EKS + metastore
EKS_CLUSTER=my-spark-eks
RDS_ENDPOINT=my-metastore.xxxxxxxx.us-east-1.rds.amazonaws.com
RDS_ID=xxxxxxxx                              # the RDS resource id portion of the endpoint

# CLI profile used by aws/kubectl/terraform (see reproduce/ENV_SETUP.md)
AWS_PROFILE=my-deploy-profile
