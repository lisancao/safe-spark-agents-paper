# EnvironmentFile for envoy.service. Copy to /etc/envoy/auth-proxy.env, set the real token, and:
#   sudo chmod 600 /etc/envoy/auth-proxy.env
#   sudo chown root:root /etc/envoy/auth-proxy.env
#
# This MUST equal the Connect server's spark.connect.authenticate.token. Envoy injects it as
# `authorization: Bearer <CONNECT_PSK>` so individual clients never hold the shared token.
CONNECT_PSK=replace-with-the-spark-connect-pre-shared-token
