# Spark Connect mTLS auth proxy (Option A auth/identity layer).
#
# Runs Envoy durably on the Connect instance: it terminates client mTLS on :15009, verifies certs
# against the Connect-layer CA, and forwards gRPC to the local Spark Connect server on 127.0.0.1:15002
# with the PSK bearer + verified x-connect-principal injected.
#
# Install (see ../README.md "Install Envoy"):
#   sudo install -d /etc/envoy/certs /run/envoy
#   sudo cp deploy/auth/envoy/envoy.yaml         /etc/envoy/envoy.yaml.tmpl
#   sudo cp deploy/auth/systemd/render-config.sh /usr/local/bin/render-envoy-config.sh
#   sudo cp deploy/auth/certs/out/server/server.crt  /etc/envoy/certs/server.crt
#   sudo cp deploy/auth/certs/out/server/server.key  /etc/envoy/certs/server.key
#   sudo cp deploy/auth/certs/out/ca/connect-ca.crt  /etc/envoy/certs/connect-ca.crt
#   sudo cp deploy/auth/systemd/auth-proxy.env.example /etc/envoy/auth-proxy.env  # then edit + chmod 600
#   sudo cp deploy/auth/systemd/envoy.service /etc/systemd/system/envoy.service
#   sudo systemctl daemon-reload && sudo systemctl enable --now envoy
#
# Assumes the envoy binary at /usr/local/bin/envoy (func-e or the official static build).

[Unit]
Description=Spark Connect mTLS auth proxy (Envoy)
After=network-online.target
Wants=network-online.target
# Start after the Connect server when co-located (best-effort; Envoy retries the upstream anyway).
After=spark-connect.service

[Service]
Type=exec
DynamicUser=yes
SupplementaryGroups=envoy-certs
EnvironmentFile=/etc/envoy/auth-proxy.env
RuntimeDirectory=envoy
Environment=ENVOY_TEMPLATE=/etc/envoy/envoy.yaml.tmpl
Environment=ENVOY_RENDERED=/run/envoy/envoy.yaml
ExecStartPre=/usr/local/bin/render-envoy-config.sh
ExecStart=/usr/local/bin/envoy -c /run/envoy/envoy.yaml --log-level info
Restart=on-failure
RestartSec=2s

# Hardening.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadOnlyPaths=/etc/envoy
# Lets Envoy bind :15009 without running as root.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
