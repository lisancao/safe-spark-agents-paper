16f9de6da5c7862241d55a13d34843404d0cbb88  hadoop-aws-3.4.2.jar
b63eb928c2ac13bde07746bcfe7fb38bbdb4b5c5  bundle-2.29.52.jar
462becf2d8ba590194e26530834ac9b58a9d3282  spark-sql-kafka-0-10_2.13-4.1.2.jar
8617f1eca0271a1c48bb5fc7ea4b067c132a319c  spark-token-provider-kafka-0-10_2.13-4.1.2.jar
