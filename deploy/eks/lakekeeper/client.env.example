# client.env.example - per-client values for the Lakekeeper governed Spark-on-EKS stack.
# Copy to client.env (git-ignored), fill in, then:   set -a; . ./client.env; set +a
# NEVER commit real secrets. The secret values below are set ONCE per engagement and kept stable
# (regenerating PG_ENCRYPTION_KEY makes the existing catalog DB unreadable; changing EXTERNAL_ID or
# CONNECT_PSK breaks vending / the gateway until every consumer is updated).

# --- identifiers (from `terraform output` after S0) -------------------------------------------
export ACCOUNT_ID="000000000000"                 # fills REPLACE-ACCOUNT
export NAME_PREFIX="ssa"                          # fills REPLACE-name-prefix-* (IAM role names)
export WAREHOUSE_BUCKET="ssa-spark-warehouse-000000000000"   # fills REPLACE-warehouse-bucket

# --- secrets (generate ONCE, keep stable, do NOT commit) --------------------------------------
export EXTERNAL_ID="REPLACE-with-TF_VAR-lakekeeper_external_id"   # MUST equal TF_VAR lakekeeper_external_id (S0). fills REPLACE-external-id
export PG_ENCRYPTION_KEY="REPLACE-32-byte-hex"    # generate once:  openssl rand -hex 16   ; fills REPLACE-PG-ENCRYPTION-KEY
export CONNECT_PSK="REPLACE-64-byte-hex"          # generate once:  openssl rand -hex 32   ; consumed by bootstrap-secrets.sh (NOT render.sh)

# --- tenants + gateway + image (per engagement) -----------------------------------------------
export TENANTS="tenant_a tenant_b"                # the client's data domains (issue-all.sh PRINCIPALS + gen_connect_server.py)
export SERVER_DNS="connect.internal localhost"    # gateway server-cert DNS SANs
export CONNECT_IMAGE="<ecr>/ssa-spark/spark-connect:4.1.2-iceberg1.11.0"  # gen_connect_server.py
