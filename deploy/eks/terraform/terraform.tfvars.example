# Copy to terraform.tfvars and adjust. DO NOT put secrets here — the RDS password is
# generated by Terraform and stored in Secrets Manager, never in this file.

aws_profile = "ssa-deploy"
region      = "us-east-1"
account_id  = ""   # optional wrong-account guard; leave empty, or set your 12-digit id

name_prefix = "ssa-spark"
environment = "prod"

# --- VPC (fresh) ---
vpc_cidr             = "10.40.0.0/16"
private_subnet_cidrs = ["10.40.0.0/20", "10.40.16.0/20"]
public_subnet_cidrs  = ["10.40.128.0/20", "10.40.144.0/20"]
single_nat_gateway   = true

# --- EKS ---
cluster_version = "1.31" # bump to 1.32 when validated; Spark 4.1 -> 4.2 lives in the image, not here
# Private API by default. To allow restricted public access instead:
# cluster_endpoint_public_access       = true
# cluster_endpoint_public_access_cidrs = ["203.0.113.10/32"]

# --- Node groups ---
system_node_instance_types   = ["m6i.large"]
system_node_desired_size     = 2
executor_node_instance_types = ["m6i.2xlarge"]
executor_capacity_type       = "ON_DEMAND" # or "SPOT" for cheaper executors
executor_node_min_size       = 0
executor_node_max_size       = 10
executor_node_desired_size   = 2

# --- IRSA service-account bindings (match your k8s manifests) ---
spark_namespace       = "spark"
spark_service_account = "spark"
hms_namespace         = "hive-metastore"
hms_service_account   = "hive-metastore"

# --- S3 warehouse ---
# warehouse_bucket_name = ""  # empty => derived as <name_prefix>-warehouse-<account_id>
warehouse_prefixes = ["bronze", "silver", "gold"]

# --- RDS metastore ---
metastore_db_name  = "metastore"
rds_engine_version = "16.4"
rds_instance_class = "db.t3.medium"
rds_multi_az       = true

# --- Operator access ---
create_bastion = false # set true for an SSM bastion to reach the private API
