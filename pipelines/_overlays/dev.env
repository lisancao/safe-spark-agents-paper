# Dev overlay: laptop / sandbox. Used by scripts/promote.sh.
# Promotion changes ONLY these values; pipeline code is byte-identical across overlays.
ENV_NAME=dev
CATALOG=spark_catalog
SCHEMA_PREFIX=dev_
STORAGE_ROOT=file://__REPO__/pipelines/_runtime/dev
KAFKA_BOOTSTRAP=localhost:9092
# CONNECT_REMOTE unset in dev -> spark-pipelines uses its embedded local engine
