# Prod overlay: cluster + production Unity Catalog. promote.sh applies these.
ENV_NAME=prod
CATALOG=unity
SCHEMA_PREFIX=prod_
STORAGE_ROOT=s3://YOUR_PROD_BUCKET/sdp
KAFKA_BOOTSTRAP=prod-kafka:9092
# CONNECT_REMOTE=sc://connect.prod.internal:15002/;token=...;use_ssl=true
# In prod the job runs IN the cluster with this overlay; code/graph identical to dev.
